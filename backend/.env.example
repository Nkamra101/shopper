# ----- Environment -----
APP_ENV=development
DEBUG=true
SEED_ON_STARTUP=true
DEFAULT_TIMEZONE=Asia/Kolkata

# ----- Database -----
# Local PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopper_clone

# Hosted PostgreSQL (Railway / Render / Neon / Supabase) — paste the full URL from the provider
# DATABASE_URL=postgresql://user:password@host:port/dbname

# SQLite fallback (no setup required)
# DATABASE_URL=sqlite:///./shopper.db

# ----- CORS -----
# Comma-separated list of allowed origins. No trailing slashes.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
